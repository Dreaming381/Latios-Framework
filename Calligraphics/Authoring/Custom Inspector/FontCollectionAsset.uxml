<engine:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:engine="UnityEngine.UIElements" xmlns:editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="True">
    <editor:PropertyField binding-path="systemFonts" name="systemFonts" />
    <editor:PropertyField binding-path="streamingAssetFonts" name="streamingAssetFonts" />
    <engine:Button text="Process!" name="ProcessButton" style="-unity-font-style: bold; font-size: 37px;" />
    <editor:PropertyField name="fontReferences" binding-path="fontReferences" />
    <editor:PropertyField binding-path="fontFamilies" name="fontFamilies" />
</engine:UXML>
